# Optional Bearer token
# if non-empty, every request must carry a matching "Authorization: Bearer <token>" header.
# Set "" to disable.
AUTH_TOKEN = your_auth_token_here
# comma-separated list of users to watch; empty = watch all
WATCH_USERS = user1, user2, user3

# ── Telegram Configuration ────────────────────────────────────────────────────
TELEGRAM_TOKEN    = "00000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
CHAT_ID           = "-000000000"
MESSAGE_THREAD_ID = "0"
PROXIES           = "http://proxy.server:8080" # set empty to disable

# ── Behaviour ─────────────────────────────────────────────────────────────────
MAX_LOG_BYTES = 1048576   # 1MB
RETRY_COUNT   = 3
RETRY_DELAY   = 5         # seconds between retries